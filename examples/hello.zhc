/**
 * Hello World 示例
 * ZHC 中文C编译器入门示例
 * 
 * 这是最简单的 ZHC 程序，演示基本语法和输出。
 */

// 主函数：程序入口
整数型 主函数() {
    // 打印欢迎消息
    打印("你好，ZHC！欢迎来到中文编程世界！\n");
    
    // 返回 0 表示程序成功结束
    返回 0;
}

/**
 * 编译方法：
 *   zhc compile hello.zhc -o hello.c
 *   gcc hello.c -o hello
 *   ./hello
 * 
 * 输出：
 *   你好，ZHC！欢迎来到中文编程世界！
 */