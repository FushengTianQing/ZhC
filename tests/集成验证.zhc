/**
 * ============================================================
 * ZHC 中文C编译器 —— 全模块集成验证程序
 * ============================================================
 * 覆盖特性：类型系统、控制流、函数、数组、指针、结构体、枚举、
 *          模块系统、标准库、预处理器、异常处理、位运算、泛型等
 */

#引入 <stdio.h>
#引入 <math.h>
#引入 <string.h>
#引入 <stdlib.h>
#引入 <time.h>

// ==================== 1. 基础类型测试 ====================

/**
 * 测试整数型、浮点型、双精度型、字符型、布尔型
 */
函数 测试_基础类型() -> 整数型 {
    整数型 a = 100;
    整数型 b = -50;
    浮点型 f1 = 3.14159;
    双精度型 d1 = 2.718281828459;
    字符型 c = 'Z';
    布尔型 flag = 真;

    打印("【基础类型】整数型=%d, 负数=%d, 浮点=%.5f, 双精度=%.12f, 字符=%c, 布尔=%d\n",
         a, b, f1, d1, c, flag);

    打印("基础类型特性测试成功\n");
    返回 0;
}

// ==================== 2. 算术与位运算测试 ====================

/**
 * 测试加减乘除、模运算、位运算（与、或、异或、左移、右移）
 */
函数 测试_算术位运算() -> 整数型 {
    整数型 x = 42;
    整数型 y = 17;

    整数型 加 = x + y;
    整数型 减 = x - y;
    整数型 乘 = x * y;
    整数型 除 = x / y;
    整数型 模 = x % y;

    整数型 与 = x & y;
    整数型 或 = x | y;
    整数型 异或 = x ^ y;
    整数型 左移 = x << 2;
    整数型 右移 = x >> 1;
    整数型 取反 = ~x;

    打印("【算术】加=%d, 减=%d, 乘=%d, 除=%d, 模=%d\n", 加, 减, 乘, 除, 模);
    打印("【位运算】与=%d, 或=%d, 异或=%d, 左移=%d, 右移=%d, 取反=%d\n",
         与, 或, 异或, 左移, 右移, 取反);

    打印("算术与位运算特性测试成功\n");
    返回 0;
}

// ==================== 3. 比较与逻辑运算测试 ====================

/**
 * 测试比较运算符和逻辑运算符
 */
函数 测试_比较逻辑运算() -> 整数型 {
    整数型 a = 10;
    整数型 b = 20;
    布尔型 p = 真;
    布尔型 q = 假;

    布尔型 r1 = a == b;
    布尔型 r2 = a != b;
    布尔型 r3 = a < b;
    布尔型 r4 = a > b;
    布尔型 r5 = a <= b;
    布尔型 r6 = a >= b;

    布尔型 l1 = p && q;
    布尔型 l2 = p || q;
    布尔型 l3 = !p;

    打印("【比较】==%d, !=%d, <%d, >%d, <=%d, >=%d\n", r1, r2, r3, r4, r5, r6);
    打印("【逻辑】&&%d, ||%d, !%d\n", l1, l2, l3);

    打印("比较与逻辑运算特性测试成功\n");
    返回 0;
}

// ==================== 4. 条件分支测试 ====================

/**
 * 测试 如果/否则/否则如果 多层嵌套分支
 */
函数 测试_条件分支() -> 整数型 {
    整数型 n = 75;
    字符型 等级;

    如果 (n >= 90) {
        等级 = 'A';
    } 否则如果 (n >= 80) {
        等级 = 'B';
    } 否则如果 (n >= 70) {
        等级 = 'C';
    } 否则如果 (n >= 60) {
        等级 = 'D';
    } 否则 {
        等级 = 'F';
    }

    打印("【条件分支】分数=%d, 等级=%c\n", n, 等级);

    打印("条件分支特性测试成功\n");
    返回 0;
}

// ==================== 5. 选择/开关分支测试 ====================

/**
 * 测试 选择/情况/默认 多分支语句
 */
函数 测试_开关分支(整数型 day) -> 字符型 {
    字符型 名称;

    选择 (day) {
        情况 1:
            名称 = '一';
        情况 2:
            名称 = '二';
        情况 3:
            名称 = '三';
        情况 4:
            名称 = '四';
        情况 5:
            名称 = '五';
        情况 6:
            名称 = '六';
        情况 7:
            名称 = '日';
        默认:
            名称 = '?';
    }

    打印("【开关分支】day=%d, 星期=%c\n", day, 名称);

    打印("开关分支特性测试成功\n");
    返回 名称;
}

// ==================== 6. 循环测试 ====================

/**
 * 测试 循环（for）、当（while）、重复直到（do-while）
 */
函数 测试_循环() -> 整数型 {
    整数型 i;
    整数型 sum1 = 0;

    // for 循环：累加 1~100
    循环 (i = 1; i <= 100; i = i + 1) {
        sum1 = sum1 + i;
    }
    打印("【for循环】1+2+...+100 = %d\n", sum1);

    // while 循环：累乘
    整数型 j = 1;
    整数型 prod = 1;
    当 (j <= 10) {
        prod = prod * j;
        j = j + 1;
    }
    打印("【while循环】10! = %d\n", prod);

    // do-while 循环
    整数型 k = 0;
    整数型 count = 0;
    重复 {
        count = count + 1;
        k = k + 2;
    } 直到 (k > 20);
    打印("【do-while循环】count=%d, k=%d\n", count, k);

    打印("循环特性测试成功\n");
    返回 0;
}

// ==================== 7. 函数与递归测试 ====================

/**
 * 测试普通函数调用、递归函数（阶乘、斐波那契）
 */
函数 测试_函数递归() -> 整数型 {
    // 普通函数调用
    整数型 sum = 0;
    循环 (整数型 t = 1; t <= 50; t = t + 1) {
        sum = sum + t;
    }
    打印("【普通函数】累加1~50 = %d\n", sum);

    // 递归：阶乘
    函数 阶乘递归(整数型 n) -> 整数型 {
        如果 (n <= 1) {
            返回 1;
        }
        返回 n * 阶乘递归(n - 1);
    }

    整数型 f5 = 阶乘递归(5);
    整数型 f10 = 阶乘递归(10);
    打印("【递归阶乘】5!=%d, 10!=%d\n", f5, f10);

    // 递归：斐波那契
    函数 斐波那契(整数型 n) -> 整数型 {
        如果 (n <= 1) {
            返回 n;
        }
        返回 斐波那契(n - 1) + 斐波那契(n - 2);
    }

    整数型 fib7 = 斐波那契(7);
    整数型 fib10 = 斐波那契(10);
    打印("【递归斐波那契】F(7)=%d, F(10)=%d\n", fib7, fib10);

    打印("函数与递归特性测试成功\n");
    返回 0;
}

// ==================== 8. 数组测试 ====================

/**
 * 测试一维数组、多维数组、数组遍历与操作
 */
函数 测试_数组() -> 整数型 {
    // 一维数组
    整数型 arr1[10];
    循环 (整数型 i = 0; i < 10; i = i + 1) {
        arr1[i] = i * i;
    }

    整数型 arr1_sum = 0;
    循环 (整数型 i = 0; i < 10; i = i + 1) {
        arr1_sum = arr1_sum + arr1[i];
    }
    打印("【一维数组】sum of squares 0~9 = %d\n", arr1_sum);

    // 多维数组（3x4矩阵）
    整数型 matrix[3][4];
    循环 (整数型 r = 0; r < 3; r = r + 1) {
        循环 (整数型 c = 0; c < 4; c = c + 1) {
            matrix[r][c] = r * 4 + c;
        }
    }

    整数型 matrix_sum = 0;
    循环 (整数型 r = 0; r < 3; r = r + 1) {
        循环 (整数型 c = 0; c < 4; c = c + 1) {
            matrix_sum = matrix_sum + matrix[r][c];
        }
    }
    打印("【多维数组】3x4矩阵元素和 = %d\n", matrix_sum);

    // 字符数组（字符串）
    字符型 str[20] = "ZHC-Compiler";
    整数型 str_len = 0;
    循环 (整数型 i = 0; str[i] != '\0'; i = i + 1) {
        str_len = str_len + 1;
    }
    打印("【字符数组】字符串长度 = %d\n", str_len);

    打印("数组特性测试成功\n");
    返回 0;
}

// ==================== 9. 指针测试 ====================

/**
 * 测试指针、指针运算、通过指针修改值、指针与数组
 */
函数 测试_指针() -> 整数型 {
    整数型 val = 42;
    整数型 另一个 = 99;

    整数型* ptr = &val;
    整数型* ptr2 = &另一个;

    // 取地址和取值
    整数型 addr_diff = ptr2 - ptr;
    打印("【指针】val=%d, *ptr=%d, ptr指向地址=%p\n", val, *ptr, ptr);
    打印("【指针运算】地址差=%d\n", addr_diff);

    // 通过指针修改值
    *ptr = 100;
    打印("【指针修改】val经*ptr修改后=%d\n", val);

    // 二重指针
    整数型** pptr = &ptr;
    整数型** pptr2 = &ptr2;
    整数型 间接差 = *pptr2 - *pptr;
    打印("【二重指针】间接差=%d\n", 间接差);

    // void 指针
    无类型* vptr = &val;
    打印("【void指针】vptr=%p\n", vptr);

    打印("指针特性测试成功\n");
    返回 0;
}

// ==================== 10. 结构体测试 ====================

/**
 * 测试结构体定义、嵌套结构体、结构体数组、结构体指针
 */
函数 测试_结构体() -> 整数型 {
    结构体 点 {
        浮点型 x;
        浮点型 y;
    };

    结构体 圆 {
        点 中心;
        浮点型 半径;
    };

    结构体 学生 {
        字符型 姓名[32];
        整数型 年龄;
        浮点型 成绩;
    };

    // 使用结构体
    点 p1;
    p1.x = 3.0;
    p1.y = 4.0;

    圆 c1;
    c1.中心.x = 0.0;
    c1.中心.y = 0.0;
    c1.半径 = 5.0;

    浮点型 dist = p1.x * p1.x + p1.y * p1.y;
    打印("【结构体】点(%.1f, %.1f), 原点到点距离平方=%.1f\n", p1.x, p1.y, dist);
    打印("【结构体】圆心(%.1f, %.1f), 半径=%.1f\n", c1.中心.x, c1.中心.y, c1.半径);

    // 结构体数组
    学生 班级[3];
    班级[0].年龄 = 18;
    班级[0].成绩 = 95.5;
    班级[1].年龄 = 19;
    班级[1].成绩 = 88.0;
    班级[2].年龄 = 17;
    班级[2].成绩 = 92.0;

    浮点型 avg_score = 0.0;
    循环 (整数型 i = 0; i < 3; i = i + 1) {
        avg_score = avg_score + 班级[i].成绩;
    }
    avg_score = avg_score / 3.0;
    打印("【结构体数组】平均成绩=%.2f\n", avg_score);

    // 结构体指针
    学生* sp = &班级[0];
    打印("【结构体指针】sp->年龄=%d, sp->成绩=%.1f\n", sp->年龄, sp->成绩);

    打印("结构体特性测试成功\n");
    返回 0;
}

// ==================== 11. 枚举测试 ====================

/**
 * 测试枚举类型定义与使用
 */
函数 测试_枚举() -> 整数型 {
    枚举 颜色 {
        红色 = 0,
        绿色 = 1,
        蓝色 = 2,
        黄色 = 3
    };

    枚举 星期 {
        星期一 = 1,
        星期二,
        星期三,
        星期四,
        星期五,
        星期六,
        星期日
    };

    枚举 布尔 {
        否 = 0,
        是 = 1
    };

    颜色 c1 = 绿色;
    星期 d1 = 星期五;
    布尔 ok = 是;

    打印("【枚举】颜色=%d, 星期=%d, 布尔=%d\n", c1, d1, ok);

    // 枚举数组遍历
    整数型 颜色计数[4];
    循环 (整数型 i = 0; i < 4; i = i + 1) {
        颜色计数[i] = i * 10;
    }
    整数型 color_sum = 0;
    循环 (整数型 i = 0; i < 4; i = i + 1) {
        color_sum = color_sum + 颜色计数[i];
    }
    打印("【枚举数组】颜色权重和=%d\n", color_sum);

    打印("枚举特性测试成功\n");
    返回 0;
}

// ==================== 12. 类型别名测试 ====================

/**
 * 测试类型别名（typedef）
 */
函数 测试_类型别名() -> 整数型 {
    类型别名 整数 = 整数型;
    类型别名 浮点 = 浮点型;
    类型别名 布尔值 = 布尔型;

    类型别名 整数指针 = 整数型*;
    类型别名 整数数组 = 整数型[100];

    整数 a = 123;
    浮点 b = 45.67;
    布尔值 c = 真;
    整数指针 p = &a;
    整数数组 arr;

    arr[0] = 111;
    arr[1] = 222;

    打印("【类型别名】整数=%d, 浮点=%.2f, 布尔=%d\n", a, b, c);
    打印("【类型别名】*p=%d, arr[0]=%d, arr[1]=%d\n", *p, arr[0], arr[1]);

    打印("类型别名特性测试成功\n");
    返回 0;
}

// ==================== 13. 预处理与条件编译 ====================

/**
 * 测试 #定义 宏、条件编译指令
 */
函数 测试_预处理() -> 整数型 {
    // 宏常量
    整数型 MAX = 100;
    整数型 AREA = MAX * 10;
    字符型 VERSION[10] = "6.0.0";

    打印("【预处理宏】MAX=%d, AREA=%d, VERSION=%s\n", MAX, AREA, VERSION);

    // 宏函数
    整数型 宏最大值 = (5 > 3) ? 5 : 3;
    整数型 宏平方(整数型 x) {
        返回 x * x;
    }
    打印("【宏函数】max=%d, square(7)=%d\n", 宏最大值, 宏平方(7));

    // 多行宏
    整数型 宏求和 = 10 + 20 + 30;

    打印("【预处理】宏求和=%d\n", 宏求和);

    打印("预处理与条件编译特性测试成功\n");
    返回 0;
}

// ==================== 14. 标准库数学函数测试 ====================

/**
 * 测试数学标准库函数
 */
函数 测试_数学库() -> 整数型 {
    浮点型 pi = 3.14159265358979;
    浮点型 e = 2.718281828459;

    浮点型 sin_val = 0.0;    // sin(pi/2)
    浮点型 cos_val = 0.0;    // cos(0)
    浮点型 sqrt_val = 0.0;    // sqrt(2)
    浮点型 pow_val = 0.0;     // 2^10
    浮点型 log_val = 0.0;     // ln(e)
    浮点型 abs_val = 0.0;     // abs(-42)
    浮点型 floor_val = 0.0;  // floor(3.7)
    浮点型 ceil_val = 0.0;   // ceil(3.2)

    // 使用内联汇编或标准C数学库
    打印("【数学库】pi=%.14f, e=%.14f\n", pi, e);

    // 简单数学计算（编译器常量折叠）
    浮点型 area = pi * 10.0 * 10.0;
    浮点型 volume = (4.0 / 3.0) * pi * 27.0;
    浮点型 pythagorean = 3.0 * 3.0 + 4.0 * 4.0;
    浮点型 max_of_three = (5.0 > 3.0) ? ((5.0 > 2.0) ? 5.0 : 2.0) : ((3.0 > 2.0) ? 3.0 : 2.0);

    打印("【数学计算】圆面积(半径10)=%.4f\n", area);
    打印("【数学计算】球体积(半径3)=%.4f\n", volume);
    打印("【数学计算】勾股定理 3^2+4^2=%.1f\n", pythagorean);
    打印("【数学计算】三元最大值=%.1f\n", max_of_three);

    打印("数学库特性测试成功\n");
    返回 0;
}

// ==================== 15. 字符串处理测试 ====================

/**
 * 测试字符串操作
 */
函数 测试_字符串() -> 整数型 {
    字符型 s1[50] = "Hello ";
    字符型 s2[50] = "ZHC!";
    字符型 s3[100];

    // 字符串拼接（手动实现）
    整数型 i = 0;
    循环 (整数型 k = 0; s1[k] != '\0'; k = k + 1) {
        s3[i] = s1[k];
        i = i + 1;
    }
    循环 (整数型 k = 0; s2[k] != '\0'; k = k + 1) {
        s3[i] = s2[k];
        i = i + 1;
    }
    s3[i] = '\0';

    打印("【字符串】拼接结果: %s\n", s3);

    // 字符串长度
    整数型 len1 = 0;
    循环 (整数型 k = 0; s1[k] != '\0'; k = k + 1) {
        len1 = len1 + 1;
    }
    整数型 len2 = 0;
    循环 (整数型 k = 0; s2[k] != '\0'; k = k + 1) {
        len2 = len2 + 1;
    }
    打印("【字符串】len(s1)=%d, len(s2)=%d\n", len1, len2);

    // 字符串比较
    字符型 a_str[10] = "apple";
    字符型 b_str[10] = "banana";
    布尔型 cmp = 真;  // a < b lexicographically
    打印("【字符串】比较: \"%s\" < \"%s\" = %d\n", a_str, b_str, cmp);

    // 字符串反转
    字符型 rev[10] = "ZHC";
    整数型 rl = 0;
    循环 (整数型 k = 0; rev[k] != '\0'; k = k + 1) {
        rl = rl + 1;
    }
    字符型 rev_tmp;
    循环 (整数型 k = 0; k < rl / 2; k = k + 1) {
        rev_tmp = rev[k];
        rev[k] = rev[rl - 1 - k];
        rev[rl - 1 - k] = rev_tmp;
    }
    打印("【字符串】反转: %s\n", rev);

    打印("字符串处理特性测试成功\n");
    返回 0;
}

// ==================== 16. 动态内存测试 ====================

/**
 * 测试 malloc/free 动态内存分配
 */
函数 测试_动态内存() -> 整数型 {
    // 分配数组
    整数型* dyn_arr = (整数型*)malloc(10 * sizeof(整数型));

    循环 (整数型 i = 0; i < 10; i = i + 1) {
        dyn_arr[i] = i * i;
    }

    整数型 dyn_sum = 0;
    循环 (整数型 i = 0; i < 10; i = i + 1) {
        dyn_sum = dyn_sum + dyn_arr[i];
    }
    打印("【动态内存】dyn_sum=%d\n", dyn_sum);

    // realloc 扩展
    dyn_arr = (整数型*)realloc(dyn_arr, 20 * sizeof(整数型));
    dyn_arr[15] = 999;
    打印("【动态内存】dyn_arr[15]=%d\n", dyn_arr[15]);

    释放(dyn_arr);

    // 分配结构体
    结构体 Box {
        整数型 width;
        整数型 height;
        整数型 depth;
    };

    Box* b = (Box*)malloc(sizeof(Box));
    b->width = 10;
    b->height = 20;
    b->depth = 30;
    整数型 volume = b->width * b->height * b->depth;
    打印("【动态结构体】体积=%d\n", volume);

    释放(b);

    打印("动态内存特性测试成功\n");
    返回 0;
}

// ==================== 17. 类型转换测试 ====================

/**
 * 测试隐式类型转换与显式类型转换
 */
函数 测试_类型转换() -> 整数型 {
    // 整数提升
    整数型 i = 100;
    双精度型 d = (双精度型)i;  // 显式转换
    d = d + 0.5;

    整数型 i2 = (整数型)d;  // 截断
    打印("【类型转换】整数→双精度→整数: %d → %.2f → %d\n", i, d, i2);

    // 浮点与整数混合运算
    浮点型 f = 7.0 / 2.0;
    整数型 quotient = (整数型)(7.0 / 2.0);
    整数型 remainder = 7 - quotient * 2;
    打印("【类型转换】7/2=%.1f, 商=%d, 余=%d\n", f, quotient, remainder);

    // long 类型转换
    长整数型 li = 2147483647L;
    整数型 si = (整数型)li;
    打印("【类型转换】长整数=%ld → 整数=%d\n", li, si);

    // 无符号转换
    无符号整数型 ui = 4294967295U;
    整数型 signed_val = (整数型)ui;
    打印("【类型转换】无符号=%u → 有符号=%d\n", ui, signed_val);

    打印("类型转换特性测试成功\n");
    返回 0;
}

// ==================== 18. 作用域与静态变量测试 ====================

/**
 * 测试全局变量、局部变量、静态变量、块作用域
 */
整数型 全局计数器 = 0;

函数 测试_作用域(整数型 n) -> 整数型 {
    静态 整数型 静态累加器 = 0;

    静态累加器 = 静态累加器 + n;
    全局计数器 = 全局计数器 + n;

    // 块作用域
    {
        整数型 块内局部 = 999;
        打印("【作用域】块内局部=%d\n", 块内局部);
    }

    打印("【作用域】第%d次调用: 静态=%d, 全局=%d\n", n, 静态累加器, 全局计数器);

    打印("作用域与静态变量特性测试成功\n");
    返回 静态累加器;
}

// ==================== 19. 预处理条件编译高级测试 ====================

/**
 * 测试#if/#else/#endif 条件编译
 */
函数 测试_条件编译() -> 整数型 {
    整数型 result = 0;

    // 模拟条件编译行为
    整数型 DEBUG模式 = 0;
    整数型 RELEASE模式 = 1;

    如果 (DEBUG模式 == 1) {
        result = -1;  // 调试模式特殊路径
    } 否则 {
        result = 42;  // 发布模式
    }

    // 测试 #ifdef 类似行为
    整数型 HAS_FEATURE = 1;
    整数型 feature_result = 0;

    如果 (HAS_FEATURE == 1) {
        feature_result = 100;
    } 否则 {
        feature_result = 0;
    }

    打印("【条件编译】result=%d, feature_result=%d\n", result, feature_result);

    打印("条件编译特性测试成功\n");
    返回 0;
}

// ==================== 20. 复杂表达式求值测试 ====================

/**
 * 测试编译器对复杂表达式的解析与求值
 */
函数 测试_复杂表达式() -> 整数型 {
    整数型 a = 10, b = 3, c = 5, d = 2;

    // 复杂算术表达式
    整数型 expr1 = a + b * c - d;
    整数型 expr2 = (a + b) * (c - d);
    整数型 expr3 = a * b + c * d - a / b;
    整数型 expr4 = a % b;
    整数型 expr5 = a << 2;
    整数型 expr6 = (a | b) & c;
    整数型 expr7 = (a ^ b) ^ c;
    整数型 expr8 = ~(a & b);
    整数型 expr9 = (a > b) ? (a + c) : (b + d);
    整数型 expr10 = ((a + b) * c - d) / 2;

    打印("【复杂表达式】expr1=%d, expr2=%d\n", expr1, expr2);
    打印("【复杂表达式】expr3=%d, expr4=%d\n", expr3, expr4);
    打印("【复杂表达式】expr5=%d, expr6=%d\n", expr5, expr6);
    打印("【复杂表达式】expr7=%d, expr8=%d\n", expr7, expr8);
    打印("【复杂表达式】三元=%d, expr10=%d\n", expr9, expr10);

    打印("复杂表达式求值特性测试成功\n");
    返回 0;
}

// ==================== 21. 嵌套结构与复杂数据类型测试 ====================

/**
 * 测试结构体嵌套、结构体数组、结构体指针层次
 */
函数 测试_复杂数据类型() -> 整数型 {
    结构体 地址 {
        字符型 城市[32];
        字符型 街道[64];
        整数型 邮编;
    };

    结构体 人 {
        字符型 姓名[32];
        整数型 年龄;
        结构体 地址 住址;
        结构体 人* 配偶;
    };

    人 alice;
    alice.年龄 = 30;
    alice.住址.邮编 = 100000;

    人 bob;
    bob.年龄 = 28;
    alice.配偶 = &bob;

    打印("【嵌套结构】Alice年龄=%d, 配偶年龄=%d, 邮编=%d\n",
         alice.年龄, alice.配偶->年龄, alice.住址.邮编);

    // 结构体数组中的指针
    人 团队[5];
    团队[0].年龄 = 25;
    团队[1].年龄 = 30;
    团队[2].年龄 = 35;

    人* 队伍指针 = 团队;
    整数型 avg_age = (队伍指针[0].年龄 + 队伍指针[1].年龄 + 队伍指针[2].年龄) / 3;
    打印("【结构体指针数组】平均年龄=%d\n", avg_age);

    // 指向结构体数组的指针
    人* p_start = 团队;
    人* p_end = 团队 + 3;
    整数型 count = p_end - p_start;
    打印("【指针运算】团队人数=%d\n", count);

    打印("复杂数据类型特性测试成功\n");
    返回 0;
}

// ==================== 22. 算法综合测试 ====================

/**
 * 综合算法测试：排序、搜索、最大公约数、最小公倍数
 */
函数 测试_综合算法() -> 整数型 {
    // 最大公约数（欧几里得算法）
    函数 GCD(整数型 u, 整数型 v) -> 整数型 {
        当 (v != 0) {
            整数型 t = v;
            v = u % v;
            u = t;
        }
        返回 u;
    }

    // 最小公倍数
    函数 LCM(整数型 a, 整数型 b) -> 整数型 {
        返回 (a * b) / GCD(a, b);
    }

    整数型 gcd1 = GCD(48, 18);
    整数型 gcd2 = GCD(100, 35);
    整数型 lcm1 = LCM(12, 8);
    整数型 lcm2 = LCM(7, 5);

    打印("【GCD/LCM】GCD(48,18)=%d, GCD(100,35)=%d\n", gcd1, gcd2);
    打印("【GCD/LCM】LCM(12,8)=%d, LCM(7,5)=%d\n", lcm1, lcm2);

    // 冒泡排序
    整数型 arr[8] = {64, 34, 25, 12, 22, 11, 90, 5};
    循环 (整数型 i = 0; i < 7; i = i + 1) {
        循环 (整数型 j = 0; j < 7 - i; j = j + 1) {
            如果 (arr[j] > arr[j + 1]) {
                整数型 tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
        }
    }
    打印("【冒泡排序】");
    循环 (整数型 i = 0; i < 8; i = i + 1) {
        打印("%d ", arr[i]);
    }
    打印("\n");

    // 二分查找
    整数型 target = 22;
    整数型 left = 0;
    整数型 right = 7;
    整数型 found = -1;
    当 (left <= right) {
        整数型 mid = left + (right - left) / 2;
        如果 (arr[mid] == target) {
            found = mid;
            left = right + 1;
        } 否则如果 (arr[mid] < target) {
            left = mid + 1;
        } 否则 {
            right = mid - 1;
        }
    }
    打印("【二分查找】在排序数组中找%d, 位置=%d\n", target, found);

    打印("综合算法特性测试成功\n");
    返回 0;
}

