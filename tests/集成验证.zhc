    // 11. 枚举
    测试_枚举();
    打印("\n");

    // 12. 类型别名
    测试_类型别名();
    打印("\n");

    // 13. 预处理
    测试_预处理();
    打印("\n");

    // 14. 数学库
    测试_数学库();
    打印("\n");

    // 15. 字符串
    测试_字符串();
