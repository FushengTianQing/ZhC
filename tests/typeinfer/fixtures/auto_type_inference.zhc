/* 整数型主函数() { */
/*     /\* 变量类型自动推导 *\/ */
/*     自动 x = 42;              /\* 推导为 整数型 *\/ */
/*     自动 y = 3.14;            /\* 推导为 浮点型 *\/ */
/*     自动 s = "hello";         /\* 推导为 字符串型 *\/ */

/*     /\* 表达式类型推导 *\/ */
/*     自动 z = x + 10;          /\* 推导为 整数型 *\/ */
/*     自动 w = y * 2.0;         /\* 推导为 浮点型 *\/ */

/*     /\* 比较表达式类型推导 *\/ */
/*     自动 cmp = x < 100;       /\* 推导为 布尔型 *\/ */

/*     打印("%d\n", x); */
/*     打印("%f\n", y); */
/*     打印("%s\n", s); */

/*     返回 0; */
/* } */

/* /\* 函数返回类型自动推导 *\/ */
/* 自动型 获取最大值(整数型 a, 整数型 b) { */
/*     如果 (a > b) { */
/*         返回 a; */
/*     } 否则 { */
/*         返回 b; */
/*     } */
/* } */

/*
模拟测试用例 - 用于验证语法解析
*/

整数型 主函数() {
    整数型 x;
    x = 42;
    返回 x;
}

整数型 加法(整数型 a, 整数型 b) {
    返回 a + b;
}
