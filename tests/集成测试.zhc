/**
 * ZHC 中文 C 编译器 - 核心功能测试
 */

// 测试 1: 整数运算
整数型 测试_整数运算() {
    整数型 a = 10;
    整数型 b = 20;
    整数型 c = a + b;
    整数型 d = a * b;
    整数型 e = b - a;
    
    打印("整数运算: a=%d, b=%d, a+b=%d, a*b=%d, b-a=%d\n", a, b, c, d, e);
    打印("整数运算特性测试成功\n");
    返回 0;
}

// 测试 2: for 循环
整数型 测试_FOR循环() {
    整数型 sum = 0;
    
    循环 (整数型 i = 1; i <= 100; i = i + 1) {
        sum = sum + i;
    }
    
    打印("FOR循环: 1+2+...+100 = %d\n", sum);
    打印("FOR循环特性测试成功\n");
    返回 0;
}

// 测试 3: while 循环
整数型 测试_WHILE循环() {
    整数型 n = 1;
    整数型 prod = 1;
    
    当 (n <= 10) {
        prod = prod * n;
        n = n + 1;
    }
    
    打印("WHILE循环: 10! = %d\n", prod);
    打印("WHILE循环特性测试成功\n");
    返回 0;
}

// 测试 4: 递归函数
整数型 阶乘(整数型 n) {
    如果 (n <= 1) {
        返回 1;
    }
    返回 n * 阶乘(n - 1);
}

整数型 测试_递归() {
    整数型 f5 = 阶乘(5);
    
    打印("递归: 5! = %d\n", f5);
    打印("递归特性测试成功\n");
    返回 0;
}

// 测试 5: 函数调用
整数型 加法(整数型 a, 整数型 b) {
    返回 a + b;
}

整数型 测试_函数调用() {
    整数型 result = 加法(3, 7);
    
    打印("函数调用: 3+7=%d\n", result);
    打印("函数调用特性测试成功\n");
    返回 0;
}

// 测试 6: 全局变量
整数型 全局计数器 = 0;

整数型 测试_全局变量() {
    全局计数器 = 全局计数器 + 1;
    
    打印("全局变量: 计数器=%d\n", 全局计数器);
    打印("全局变量特性测试成功\n");
    返回 0;
}

// 主函数
整数型 主函数() {
    打印("\n");
    打印("============================================\n");
    打印("  ZHC 中文 C 编译器 - 核心功能测试\n");
    打印("============================================\n");
    打印("\n");
    
    测试_整数运算();
    打印("\n");
    
    测试_FOR循环();
    打印("\n");
    
    测试_WHILE循环();
    打印("\n");
    
    测试_递归();
    打印("\n");
    
    测试_函数调用();
    打印("\n");
    
    测试_全局变量();
    打印("\n");
    
    打印("============================================\n");
    打印("  所有测试完成!\n");
    打印("============================================\n");
    
    返回 0;
}
