/*
多模块示例
演示模块间的导入和依赖关系
*/

模块 工具库 {
    公开:
        // 工具函数
        函数 最大值(整数型 a, 整数型 b) -> 整数型 {
            如果 (a > b) {
                返回 a;
            } 否则 {
                返回 b;
            }
        }
        
        函数 最小值(整数型 a, 整数型 b) -> 整数型 {
            如果 (a < b) {
                返回 a;
            } 否则 {
                返回 b;
            }
        }
        
        // 工具常量
        整数型 最大整数值 = 2147483647;
        整数型 最小整数值 = -2147483648;
        
    私有:
        // 内部工具函数
        函数 交换(整数型* a, 整数型* b) -> 无类型 {
            整数型 临时 = *a;
            *a = *b;
            *b = 临时;
        }
}

模块 数学库 {
    公开:
        // 数学函数
        函数 平方(整数型 x) -> 整数型 {
            返回 x * x;
        }
        
        函数 立方(整数型 x) -> 整数型 {
            返回 x * x * x;
        }
        
        // 使用工具库的函数
        函数 最大平方(整数型 a, 整数型 b) -> 整数型 {
            整数型 平方a = 平方(a);
            整数型 平方b = 平方(b);
            返回 工具库.最大值(平方a, 平方b);
        }
        
        // 数学常量
        浮点型 圆周率 = 3.1415926535;
        浮点型 自然对数底 = 2.7182818284;
        
    私有:
        // 内部计算函数
        函数 阶乘(整数型 n) -> 整数型 {
            如果 (n <= 1) {
                返回 1;
            }
            返回 n * 阶乘(n - 1);
        }
}

模块 主程序 {
    公开:
        // 主函数
        函数 主函数() -> 整数型 {
            // 使用数学库
            整数型 结果1 = 数学库.平方(5);
            整数型 结果2 = 数学库.立方(3);
            
            // 使用工具库
            整数型 最大值 = 工具库.最大值(结果1, 结果2);
            
            // 输出结果
            打印("平方(5) = %d\\n", 结果1);
            打印("立方(3) = %d\\n", 结果2);
            打印("最大值 = %d\\n", 最大值);
            
            返回 0;
        }
}

// 导入依赖
导入 工具库;
导入 数学库;