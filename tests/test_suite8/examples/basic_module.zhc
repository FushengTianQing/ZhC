/*
基础模块示例
用于测试套件8的示例文件
*/

模块 数学库 {
    公开:
        // 公开函数
        函数 加法(整数型 a, 整数型 b) -> 整数型 {
            返回 a + b;
        }
        
        函数 减法(整数型 a, 整数型 b) -> 整数型 {
            返回 a - b;
        }
        
        // 公开常量
        整数型 常量圆周率 = 3;
        
    私有:
        // 私有辅助函数
        函数 内部计算(整数型 x) -> 整数型 {
            返回 x * x;
        }
        
        // 私有变量
        浮点型 内部因子 = 1.5;
}

// 导入其他模块
导入 工具库;
导入 字符串处理库;