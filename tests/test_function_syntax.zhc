// 测试函数语法 v4.0

#include <stdio.h>

// 基础函数声明
函数 求和(整数型 a, 整数型 b) -> 整数型 {
    返回 a + b;
}

// 无参数函数
函数 打印问候语() -> 无类型 {
    打印("你好，世界！\n");
}

// 复杂参数类型
函数 处理数组(整数型 数组[], 整数型 长度) -> 无类型 {
    循环 (整数型 i = 0; i < 长度; i++) {
        打印("数组[%d] = %d\n", i, 数组[i]);
    }
}

// 使用中文类型
函数 中文求和(中文整数型 a, 中文整数型 b) -> 中文整数型 {
    返回 a + b;
}

// 结构体参数
结构体 点 {
    浮点型 x;
    浮点型 y;
};

函数 计算距离(结构体 点 p1, 结构体 点 p2) -> 浮点型 {
    浮点型 dx = p1.x - p2.x;
    浮点型 dy = p1.y - p2.y;
    返回 dx * dx + dy * dy;
}

// 主函数
整数型 主函数() {
    整数型 结果 = 求和(10, 20);
    打印("求和结果: %d\n", 结果);
    
    打印问候语();
    
    整数型 数组[5] = {1, 2, 3, 4, 5};
    处理数组(数组, 5);
    
    整数型 中文结果 = 中文求和(30, 40);
    打印("中文求和结果: %d\n", 中文结果);
    
    结构体 点 点1 = {0.0, 0.0};
    结构体 点 点2 = {3.0, 4.0};
    浮点型 距离平方 = 计算距离(点1, 点2);
    打印("距离平方: %f\n", 距离平方);
    
    返回 0;
}