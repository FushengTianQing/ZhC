// 测试标准库函数 v5.0

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>
#include <time.h>
#include <ctype.h>

// 测试各种标准库函数
整数型 主函数() {
    // 内存管理测试
    整数型* 指针 = (整数型*)申请(sizeof(整数型) * 10);
    如果 (指针 == NULL) {
        打印("内存申请失败\n");
        返回 1;
    }
    
    内存设置(指针, 0, sizeof(整数型) * 10);
    
    循环 (整数型 i = 0; i < 10; i++) {
        指针[i] = i * i;
    }
    
    打印("内存管理测试: ");
    循环 (整数型 i = 0; i < 10; i++) {
        打印("%d ", 指针[i]);
    }
    打印("\n");
    
    释放(指针);
    
    // 字符串操作测试
    字符型 字符串1[50] = "Hello, ";
    字符型 字符串2[] = "World!";
    
    字符串连接(字符串1, 字符串2);
    打印("字符串连接: %s\n", 字符串1);
    
    整数型 长度 = 字符串长度(字符串1);
    打印("字符串长度: %d\n", 长度);
    
    // 数学函数测试
    双精度浮点型 x = 16.0;
    双精度浮点型 平方根值 = 平方根(x);
    双精度浮点型 幂值 = 幂函数(2.0, 3.0);
    双精度浮点型 正弦值 = 正弦(3.14159 / 6.0);  // sin(π/6) = 0.5
    
    打印("数学函数测试:\n");
    打印("  平方根(%.1f) = %.4f\n", x, 平方根值);
    打印("  2^3 = %.1f\n", 幂值);
    打印("  sin(π/6) = %.4f\n", 正弦值);
    
    // 字符处理测试
    字符型 字符 = 'A';
    字符型 小写字符 = 转小写(字符);
    字符型 数字字符 = '7';
    
    打印("字符处理测试:\n");
    打印("  转小写('%c') = '%c'\n", 字符, 小写字符);
    打印("  '%c' 是数字? %s\n", 数字字符, 是数字(数字字符) ? "是" : "否");
    打印("  '%c' 是字母? %s\n", 字符, 是字母(字符) ? "是" : "否");
    
    // 时间函数测试
    time_t 当前时间值 = 当前时间(NULL);
    打印("当前时间戳: %ld\n", 当前时间值);
    
    clock_t 开始时间 = 程序运行时间();
    
    // 做一些工作
    长整数型 和 = 0;
    循环 (整数型 i = 0; i < 1000000; i++) {
        和 += i;
    }
    
    clock_t 结束时间 = 程序运行时间();
    双精度浮点型 耗时毫秒 = ((双精度浮点型)(结束时间 - 开始时间)) / CLOCKS_PER_SEC * 1000;
    打印("计算耗时: %.2f 毫秒\n", 耗时毫秒);
    
    // 随机数测试
    设置种子(当前时间值);
    整数型 随机值 = 随机数() % 100;
    打印("随机数 (0-99): %d\n", 随机值);
    
    // 文件操作测试（简单演示）
    打印("所有测试完成！\n");
    
    返回 0;
}