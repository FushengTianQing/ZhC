模块 数学库 {
    公开:
        函数 加法(整数型 a, 整数型 b) -> 整数型 {
            返回 a + b;
        }

        函数 乘法(整数型 a, 整数型 b) -> 整数型 {
            返回 a * b;
        }

    私有:
        整数型 内部常量 = 100;
}

模块 主程序 {
    导入 数学库

    主函数() -> 整数型 {
        整数型 结果1 = 加法(3, 4);
        整数型 结果2 = 乘法(3, 4);

        打印("加法结果: %d\n", 结果1);
        打印("乘法结果: %d\n", 结果2);

        返回 0;
    }
}
