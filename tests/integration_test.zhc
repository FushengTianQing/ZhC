/**
 * ZhC 编译器集成测试程序
 * 
 * 本程序逐个验证 ZhC 编译器的各项特性和功能
 * 成功打印"成功"，失败打印"失败"
 * 
 * 作者：阿福
 * 日期：2026-04-11
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

// ============================================================================
// 测试辅助宏
// ============================================================================

// 测试计数器
整数型 测试通过数 = 0;
整数型 测试失败数 = 0;

// 测试断言宏
宏 测试断言(条件, 测试名称) {
    如果 (条件) {
        打印("✅ 成功: %s\n", 测试名称);
        测试通过数 = 测试通过数 + 1;
    } 否则 {
        打印("❌ 失败: %s\n", 测试名称);
        测试失败数 = 测试失败数 + 1;
    }
}

// ============================================================================
// 第一部分：基础语法测试
// ============================================================================

空型 测试基础类型() {
    打印("\n=== 第一部分：基础语法测试 ===\n");
    
    // 测试1.1: 整数型
    整数型 整数变量 = 42;
    测试断言(整数变量 == 42, "1.1 整数型声明与赋值");
    
    // 测试1.2: 浮点型
    浮点型 浮点变量 = 3.14159;
    测试断言(浮点变量 > 3.14 && 浮点变量 < 3.15, "1.2 浮点型声明与赋值");
    
    // 测试1.3: 字符型
    字符型 字符变量 = 'A';
    测试断言(字符变量 == 'A', "1.3 字符型声明与赋值");
    
    // 测试1.4: 双精度浮点型
    双精度浮点型 双精度变量 = 2.718281828;
    测试断言(双精度变量 > 2.71 && 双精度变量 < 2.72, "1.4 双精度浮点型声明与赋值");
    
    // 测试1.5: 长整数型
    长整数型 长整数变量 = 123456789L;
    测试断言(长整数变量 == 123456789L, "1.5 长整数型声明与赋值");
    
    // 测试1.6: 常量修饰符
    常量 整数型 常量整数 = 100;
    测试断言(常量整数 == 100, "1.6 常量修饰符");
    
    // 测试1.7: 静态修饰符
    静态 整数型 静态整数 = 200;
    测试断言(静态整数 == 200, "1.7 静态修饰符");
}

空型 测试控制流() {
    打印("\n--- 控制流测试 ---\n");
    
    // 测试1.8: 如果语句
    整数型 条件值 = 10;
    整数型 结果 = 0;
    如果 (条件值 > 5) {
        结果 = 1;
    }
    测试断言(结果 == 1, "1.8 如果语句");
    
    // 测试1.9: 如果-否则语句
    如果 (条件值 > 20) {
        结果 = 2;
    } 否则 {
        结果 = 3;
    }
    测试断言(结果 == 3, "1.9 如果-否则语句");
    
    // 测试1.10: 循环语句
    整数型 循环计数 = 0;
    循环 (整数型 i = 0; i < 5; i++) {
        循环计数 = 循环计数 + 1;
    }
    测试断言(循环计数 == 5, "1.10 循环语句");
    
    // 测试1.11: 当循环
    整数型 当计数 = 0;
    整数型 j = 0;
    当 (j < 3) {
        当计数 = 当计数 + 1;
        j = j + 1;
    }
    测试断言(当计数 == 3, "1.11 当循环");
    
    // 测试1.12: 选择语句
    整数型 选择值 = 2;
    整数型 选择结果 = 0;
    选择 (选择值) {
        分支 1:
            选择结果 = 10;
            跳出;
        分支 2:
            选择结果 = 20;
            跳出;
        默认:
            选择结果 = 0;
            跳出;
    }
    测试断言(选择结果 == 20, "1.12 选择语句");
    
    // 测试1.13: 跳出语句
    整数型 跳出计数 = 0;
    循环 (整数型 k = 0; k < 100; k++) {
        如果 (k == 5) {
            跳出;
        }
        跳出计数 = 跳出计数 + 1;
    }
    测试断言(跳出计数 == 5, "1.13 跳出语句");
    
    // 测试1.14: 继续语句
    整数型 继续计数 = 0;
    循环 (整数型 m = 0; m < 5; m++) {
        如果 (m == 2) {
            继续;
        }
        继续计数 = 继续计数 + 1;
    }
    测试断言(继续计数 == 4, "1.14 继续语句");
}

// ============================================================================
// 第二部分：函数测试
// ============================================================================

// 辅助函数
整数型 简单加法(整数型 a, 整数型 b) {
    返回 a + b;
}

整数型 递归阶乘(整数型 n) {
    如果 (n <= 1) {
        返回 1;
    }
    返回 n * 递归阶乘(n - 1);
}

空型 测试函数() {
    打印("\n=== 第二部分：函数测试 ===\n");
    
    // 测试2.1: 基本函数调用
    整数型 加法结果 = 简单加法(10, 20);
    测试断言(加法结果 == 30, "2.1 基本函数调用");
    
    // 测试2.2: 递归函数
    整数型 阶乘结果 = 递归阶乘(5);
    测试断言(阶乘结果 == 120, "2.2 递归函数");
    
    // 测试2.3: 多参数函数
    整数型 三数之和 = 简单加法(简单加法(1, 2), 3);
    测试断言(三数之和 == 6, "2.3 多参数函数");
}

// ============================================================================
// 第三部分：数组测试
// ============================================================================

空型 测试数组() {
    打印("\n=== 第三部分：数组测试 ===\n");
    
    // 测试3.1: 一维数组
    整数型 一维数组[5];
    一维数组[0] = 10;
    一维数组[1] = 20;
    一维数组[2] = 30;
    一维数组[3] = 40;
    一维数组[4] = 50;
    测试断言(一维数组[2] == 30, "3.1 一维数组");
    
    // 测试3.2: 数组初始化
    整数型 初始化数组[3] = {100, 200, 300};
    测试断言(初始化数组[1] == 200, "3.2 数组初始化");
    
    // 测试3.3: 数组求和
    整数型 数组总和 = 0;
    循环 (整数型 i = 0; i < 5; i++) {
        数组总和 = 数组总和 + 一维数组[i];
    }
    测试断言(数组总和 == 150, "3.3 数组求和");
    
    // 测试3.4: 字符数组（字符串）
    字符型 字符串[20] = "你好，ZHC";
    整数型 字符串长度 = 0;
    当 (字符串[字符串长度] != '\0') {
        字符串长度 = 字符串长度 + 1;
    }
    测试断言(字符串长度 > 0, "3.4 字符数组");
}

// ============================================================================
// 第四部分：指针测试
// ============================================================================

空型 测试指针() {
    打印("\n=== 第四部分：指针测试 ===\n");
    
    // 测试4.1: 指针声明与解引用
    整数型 值 = 42;
    整数型指针 指针 = &值;
    测试断言(*指针 == 42, "4.1 指针声明与解引用");
    
    // 测试4.2: 指针运算
    整数型 数组[3] = {10, 20, 30};
    整数型指针 数组指针 = 数组;
    数组指针 = 数组指针 + 1;
    测试断言(*数组指针 == 20, "4.2 指针运算");
    
    // 测试4.3: 空指针
    整数型指针 空指针 = NULL;
    测试断言(空指针 == NULL, "4.3 空指针");
}

// ============================================================================
// 第五部分：结构体测试
// ============================================================================

结构体 点 {
    整数型 x;
    整数型 y;
};

结构体 矩形 {
    结构体 点 左上;
    结构体 点 右下;
};

空型 测试结构体() {
    打印("\n=== 第五部分：结构体测试 ===\n");
    
    // 测试5.1: 结构体声明与访问
    结构体 点 点1;
    点1.x = 10;
    点1.y = 20;
    测试断言(点1.x == 10 && 点1.y == 20, "5.1 结构体声明与访问");
    
    // 测试5.2: 结构体初始化
    结构体 点 点2 = {30, 40};
    测试断言(点2.x == 30 && 点2.y == 40, "5.2 结构体初始化");
    
    // 测试5.3: 嵌套结构体
    结构体 矩形 矩形1 = {{0, 0}, {100, 100}};
    测试断言(矩形1.右下.x == 100, "5.3 嵌套结构体");
    
    // 测试5.4: 结构体指针
    结构体 点指针 点指针 = &点1;
    测试断言(点指针->x == 10, "5.4 结构体指针");
}

// ============================================================================
// 第六部分：内存管理测试
// ============================================================================

空型 测试内存管理() {
    打印("\n=== 第六部分：内存管理测试 ===\n");
    
    // 测试6.1: 动态内存分配
    整数型指针 动态内存 = (整数型指针)申请(sizeof(整数型) * 5);
    测试断言(动态内存 != NULL, "6.1 动态内存分配");
    
    // 测试6.2: 内存使用
    如果 (动态内存 != NULL) {
        循环 (整数型 i = 0; i < 5; i++) {
            动态内存[i] = i * 10;
        }
        测试断言(动态内存[3] == 30, "6.2 内存使用");
        释放(动态内存);
    }
    
    // 测试6.3: calloc
    整数型指针 清零内存 = (整数型指针)申请数组(5, sizeof(整数型));
    如果 (清零内存 != NULL) {
        测试断言(清零内存[0] == 0, "6.3 calloc清零内存");
        释放(清零内存);
    }
}

// ============================================================================
// 第七部分：字符串操作测试
// ============================================================================

空型 测试字符串操作() {
    打印("\n=== 第七部分：字符串操作测试 ===\n");
    
    // 测试7.1: 字符串长度
    字符型 字符串1[] = "Hello, ZHC!";
    整数型 长度 = 字符串长度(字符串1);
    测试断言(长度 == 11, "7.1 字符串长度");
    
    // 测试7.2: 字符串复制
    字符型 目标[50];
    字符串复制(目标, 字符串1);
    测试断言(字符串比较(目标, 字符串1) == 0, "7.2 字符串复制");
    
    // 测试7.3: 字符串连接
    字符型 连接结果[100] = "Hello, ";
    字符串连接(连接结果, "World!");
    测试断言(字符串比较(连接结果, "Hello, World!") == 0, "7.3 字符串连接");
    
    // 测试7.4: 字符串比较
    整数型 比较结果 = 字符串比较("abc", "abd");
    测试断言(比较结果 < 0, "7.4 字符串比较");
    
    // 测试7.5: 字符串查找
    字符型指针 查找结果 = 查找子串(字符串1, "ZHC");
    测试断言(查找结果 != NULL, "7.5 字符串查找");
}

// ============================================================================
// 第八部分：数学函数测试
// ============================================================================

空型 测试数学函数() {
    打印("\n=== 第八部分：数学函数测试 ===\n");
    
    // 测试8.1: 平方根
    双精度浮点型 平方根结果 = 平方根(16.0);
    测试断言(平方根结果 > 3.99 && 平方根结果 < 4.01, "8.1 平方根");
    
    // 测试8.2: 幂运算
    双精度浮点型 幂结果 = 幂函数(2.0, 10.0);
    测试断言(幂结果 > 1023.9 && 幂结果 < 1024.1, "8.2 幂运算");
    
    // 测试8.3: 三角函数
    双精度浮点型 正弦结果 = 正弦(3.14159 / 6.0);
    测试断言(正弦结果 > 0.49 && 正弦结果 < 0.51, "8.3 正弦函数");
    
    // 测试8.4: 取整函数
    双精度浮点型 向上取整结果 = 向上取整(3.2);
    测试断言(向上取整结果 == 4.0, "8.4 向上取整");
    
    双精度浮点型 向下取整结果 = 向下取整(3.8);
    测试断言(向下取整结果 == 3.0, "8.4 向下取整");
    
    // 测试8.5: 绝对值
    整数型 绝对值结果 = 绝对值(-42);
    测试断言(绝对值结果 == 42, "8.5 绝对值");
}

// ============================================================================
// 第九部分：类型转换测试
// ============================================================================

空型 测试类型转换() {
    打印("\n=== 第九部分：类型转换测试 ===\n");
    
    // 测试9.1: 隐式类型转换
    整数型 整数值 = 10;
    浮点型 浮点值 = 整数值;
    测试断言(浮点值 == 10.0, "9.1 隐式类型转换");
    
    // 测试9.2: 显式类型转换
    浮点型 浮点数 = 3.7;
    整数型 转换后整数 = (整数型)浮点数;
    测试断言(转换后整数 == 3, "9.2 显式类型转换");
    
    // 测试9.3: 字符串转整数
    整数型 字符串转整数结果 = 字符串转整数("12345");
    测试断言(字符串转整数结果 == 12345, "9.3 字符串转整数");
    
    // 测试9.4: 整数转字符串
    字符型 整数转字符串缓冲[20];
    格式化打印到字符串(整数转字符串缓冲, 20, "%d", 42);
    测试断言(字符串比较(整数转字符串缓冲, "42") == 0, "9.4 整数转字符串");
}

// ============================================================================
// 第十部分：位运算测试
// ============================================================================

空型 测试位运算() {
    打印("\n=== 第十部分：位运算测试 ===\n");
    
    // 测试10.1: 按位与
    整数型 与结果 = 0x0F & 0x55;
    测试断言(与结果 == 0x05, "10.1 按位与");
    
    // 测试10.2: 按位或
    整数型 或结果 = 0x0F | 0x55;
    测试断言(或结果 == 0x5F, "10.2 按位或");
    
    // 测试10.3: 按位异或
    整数型 异或结果 = 0x0F ^ 0x55;
    测试断言(异或结果 == 0x5A, "10.3 按位异或");
    
    // 测试10.4: 按位取反
    整数型 取反结果 = ~0x0F;
    测试断言((取反结果 & 0xFF) == 0xF0, "10.4 按位取反");
    
    // 测试10.5: 左移
    整数型 左移结果 = 1 << 4;
    测试断言(左移结果 == 16, "10.5 左移");
    
    // 测试10.6: 右移
    整数型 右移结果 = 16 >> 2;
    测试断言(右移结果 == 4, "10.6 右移");
}

// ============================================================================
// 第十一部分：枚举与联合体测试
// ============================================================================

枚举 颜色 {
    红色,
    绿色,
    蓝色
};

共用体 数据 {
    整数型 整数部分;
    浮点型 浮点部分;
    字符型 字符部分[4];
};

空型 测试枚举与联合体() {
    打印("\n=== 第十一部分：枚举与联合体测试 ===\n");
    
    // 测试11.1: 枚举声明
    枚举 颜色 颜色变量 = 绿色;
    测试断言(颜色变量 == 1, "11.1 枚举声明");
    
    // 测试11.2: 枚举比较
    如果 (颜色变量 == 绿色) {
        测试断言(1, "11.2 枚举比较");
    } 否则 {
        测试断言(0, "11.2 枚举比较");
    }
    
    // 测试11.3: 联合体大小
    测试断言(sizeof(共用体 数据) >= sizeof(整数型), "11.3 联合体大小");
    
    // 测试11.4: 联合体成员访问
    共用体 数据 联合变量;
    联合变量.整数部分 = 42;
    测试断言(联合变量.整数部分 == 42, "11.4 联合体成员访问");
}

// ============================================================================
// 第十二部分：类型别名测试
// ============================================================================

别名 整数指针 = 整数型指针;
别名 字符串 = 字符型指针;
别名 大整数 = 长整数型;

空型 测试类型别名() {
    打印("\n=== 第十二部分：类型别名测试 ===\n");
    
    // 测试12.1: 基本类型别名
    大整数 大数值 = 999999999L;
    测试断言(大数值 == 999999999L, "12.1 基本类型别名");
    
    // 测试12.2: 指针类型别名
    整数型 值 = 100;
    整数指针 指针别名 = &值;
    测试断言(*指针别名 == 100, "12.2 指针类型别名");
    
    // 测试12.3: 字符串类型别名
    字符串 字符串别名 = "测试字符串";
    测试断言(字符串别名[0] == '测', "12.3 字符串类型别名");
}

// ============================================================================
// 第十三部分：预处理指令测试
// ============================================================================

宏 最大值(A, B) ((A) > (B) ? (A) : (B))
宏 最小值(A, B) ((A) < (B) ? (A) : (B))
宏 平方(X) ((X) * (X))

空型 测试预处理指令() {
    打印("\n=== 第十三部分：预处理指令测试 ===\n");
    
    // 测试13.1: 宏定义
    整数型 宏结果1 = 最大值(10, 20);
    测试断言(宏结果1 == 20, "13.1 宏定义 - 最大值");
    
    // 测试13.2: 宏计算
    整数型 宏结果2 = 平方(5);
    测试断言(宏结果2 == 25, "13.2 宏定义 - 平方");
    
    // 测试13.3: 嵌套宏
    整数型 宏结果3 = 最大值(平方(3), 平方(4));
    测试断言(宏结果3 == 16, "13.3 嵌套宏");
}

// ============================================================================
// 第十四部分：文件操作测试
// ============================================================================

空型 测试文件操作() {
    打印("\n=== 第十四部分：文件操作测试 ===\n");
    
    // 测试14.1: 文件打开与关闭
    文件指针 文件 = 打开文件("test_output.txt", "w");
    测试断言(文件 != NULL, "14.1 文件打开");
    
    如果 (文件 != NULL) {
        // 测试14.2: 文件写入
        整数型 写入结果 = 格式化打印到文件(文件, "测试数据: %d\n", 42);
        测试断言(写入结果 > 0, "14.2 文件写入");
        
        关闭文件(文件);
        
        // 测试14.3: 文件读取
        文件 = 打开文件("test_output.txt", "r");
        如果 (文件 != NULL) {
            字符型 缓冲区[100];
            如果 (读取字符串(缓冲区, 100, 文件) != NULL) {
                测试断言(字符串长度(缓冲区) > 0, "14.3 文件读取");
            }
            关闭文件(文件);
        }
    }
}

// ============================================================================
// 第十五部分：随机数测试
