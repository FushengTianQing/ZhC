//===--- DiagnosticKinds.def - ZhC Diagnostic Message Definitions -----------===//
//
// This file defines all diagnostic messages for the ZhC compiler.
// Messages are organized by category and use {0}, {1}, etc. as placeholders.
//
// FORMAT: DIAG(ID, LEVEL, MESSAGE)
//   ID    - Unique diagnostic identifier (enum value)
//   LEVEL - Severity: Error, Warning, Note, Fatal
//   MESSAGE - Chinese message template with {N} placeholders
//
//===----------------------------------------------------------------------===//

#ifndef DIAG
#error "Define DIAG macro before including this file"
#endif

//===----------------------------------------------------------------------===//
// Lexer Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_invalid_character,         Error,   "非法字符 '{0}'")
DIAG(err_unterminated_string,       Error,   "未终止的字符串字面量")
DIAG(err_unterminated_char,         Error,   "未终止的字符字面量")
DIAG(err_invalid_escape,            Error,   "无效的转义字符 '\\{0}'")
DIAG(err_unexpected_eof,            Error,   "意外的文件结束")
DIAG(err_invalid_number,            Error,   "无效的数字字面量 '{0}'")
DIAG(err_unknown_character,         Error,   "未知字符: '{0}'")

//===----------------------------------------------------------------------===//
// Parser Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_expected,                  Error,   "期望 '{0}'，但得到 '{1}'")
DIAG(err_expected_declaration,      Error,   "期望声明")
DIAG(err_expected_identifier,       Error,   "期望标识符")
DIAG(err_expected_parameter_name,   Error,   "期望参数名")
DIAG(err_expected_type,             Error,   "期望类型")
DIAG(err_expected_expression,       Error,   "期望表达式")
DIAG(err_expected_case_or_default,  Error,   "期望 'case' 或 'default'")
DIAG(err_expected_semi,             Error,   "期望分号")
DIAG(err_expected_lbrace,           Error,   "期望 '{{'")
DIAG(err_expected_rbrace,           Error,   "期望 '}}'")
DIAG(err_expected_lparen,           Error,   "期望 '('")
DIAG(err_expected_rparen,           Error,   "期望 ')'")
DIAG(err_expected_colon,            Error,   "期望 ':'")

//===----------------------------------------------------------------------===//
// Sema Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_redefinition,              Error,   "标识符 '{0}' 重复定义")
DIAG(err_undefined,                 Error,   "未定义的标识符 '{0}'")
DIAG(err_type_mismatch,             Error,   "类型不匹配：期望 '{0}'，实际 '{1}'")
DIAG(err_invalid_binary_op,         Error,   "运算符 '{0}' 不能用于类型 '{1}' 和 '{2}'")
DIAG(err_invalid_unary_op,          Error,   "运算符 '{0}' 不能用于类型 '{1}'")
DIAG(err_not_callable,              Error,   "类型 '{0}' 不可调用")
DIAG(err_wrong_arg_count,           Error,   "参数数量不匹配：期望 {0} 个，实际 {1} 个")
DIAG(err_no_member,                 Error,   "类型 '{0}' 没有成员 '{1}'")
DIAG(err_uninitialized_var,         Error,   "使用了可能未初始化的变量: '{0}'")
DIAG(err_unreachable_code,          Warning, "不可达的代码")

DIAG(warn_unused_variable,          Warning, "未使用的局部变量: '{0}'")
DIAG(warn_unused_parameter,         Warning, "未使用的参数: '{0}'")
DIAG(warn_implicit_conversion,      Warning, "隐式类型转换: '{0}' 到 '{1}'")

//===----------------------------------------------------------------------===//
// Driver Diagnostics
//===----------------------------------------------------------------------===//

DIAG(fatal_cannot_open_file,        Fatal,   "无法打开文件: {0}")
DIAG(err_no_input_files,            Error,   "未指定输入文件")

//===----------------------------------------------------------------------===//
// Preprocessor Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_pp_unterminated_macro,     Error,   "宏定义缺少右括号: {0}")
DIAG(err_pp_macro_depth,            Error,   "宏展开深度超过限制: {0}")
DIAG(err_pp_invalid_include,        Error,   "无效的 #include 语法: {0}")
DIAG(err_pp_include_depth,          Error,   "#include 嵌套深度超过限制")
DIAG(err_pp_file_not_found,         Error,   "找不到头文件: {0}")
DIAG(err_pp_circular_include,       Error,   "循环包含: {0}")
DIAG(err_pp_read_error,             Error,   "无法读取头文件: {0}")

//===----------------------------------------------------------------------===//
// Code Generation Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_codegen_unsupported,       Error,   "不支持的功能: {0}")
DIAG(err_codegen_type,              Error,   "无法生成类型 '{0}' 的代码")

#undef DIAG
