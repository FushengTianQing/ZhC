# Control flow - if/while/for/switch
函数 控制流测试(整数型 x) : 整数型 {
    # if/else
    如果 (x > 0) {
        x = x + 1;
    } 否则 {
        x = x - 1;
    }

    # while loop
    变量 计数 : 整数型 = 0;
    循环 (x > 10) {
        x = x - 1;
        计数 = 计数 + 1;
    }

    # for loop
    变量 总和 : 整数型 = 0;
    对于 (变量 i = 0; i < 10; i = i + 1) {
        总和 = 总和 + i;
    }

    # switch
    选择 (x) {
        当 0:
            返回 总和;
        当 1:
            返回 计数;
        默认:
            返回 x;
    }
}
